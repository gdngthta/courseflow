# ─────────────────────────────────────────────────
# CourseFlow — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────
# Create your project at https://supabase.com
# Found in: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side ONLY (used by the cron job to
# bypass RLS when reading all users' reminder preferences and
# writing reminder_logs). NEVER expose to the browser.
# Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Telegram Reminders (Phase 4.5) ───────────────
# Create a bot with @BotFather on Telegram, then paste the token here.
# Server-side ONLY — never prefix with NEXT_PUBLIC_.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Shared secret used to authenticate Vercel Cron requests to
# /api/cron/send-reminders. Generate any random string ≥32 chars.
# Server-side ONLY — never prefix with NEXT_PUBLIC_.
CRON_SECRET=your-long-random-string-here

# Shared secret for the Telegram webhook. When set, Telegram includes
# it in the X-Telegram-Bot-Api-Secret-Token header on every webhook
# call; our route rejects requests with the wrong header. Generate
# any random alphanumeric string (1–256 chars per Telegram spec).
# Pass this as `secret_token=...` when calling setWebhook.
# Server-side ONLY — never prefix with NEXT_PUBLIC_.
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
